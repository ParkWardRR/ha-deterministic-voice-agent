  style.stroke: "#8b5cf6"
  db: {
    label: "PostgreSQL + pgvector (NVMe)"
    shape: cylinder
    style.fill: "#ddd6fe"
  }
  onnx: {
    label: "Local Intent LLM\n(Qwen 2.5 1.5B · RTX 3060 CUDA)"
