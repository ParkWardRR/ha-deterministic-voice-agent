direction: right

input: {label: "Input Phrase"; shape: oval; style.fill: "#e2e8f0"}
lexical: {label: "Lexical & Scope Filter\n(Area-based Shortcircuit)"; style.fill: "#bae6fd"}
vector: {label: "ONNX Embeddings\n(sentence-transformers)"; style.fill: "#c4b5fd"}
db: {label: "PostgreSQL pgvector\n(AVX-512 Batched Rank)"; shape: cylinder; style.fill: "#ddd6fe"}
merge: {label: "Score Merge & Dedup\n(Apply Budget Limit)"; style.fill: "#f0f4f8"}
out: {label: "Strict Menu (N ≤ 20)"; shape: oval; style.fill: "#86efac"}

input -> lexical
input -> vector

vector -> db: "Similarity Query"

lexical -> merge
db -> merge

merge -> out
